<?xml version="1.0"?>
<!--
  For more information on how to configure your ASP.NET application, please visit
  http://go.microsoft.com/fwlink/?LinkId=152368
  -->
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
  </configSections>

  <appSettings>
    <!--<add key="webpages:Version" value="1.0.0.0"/>-->
    <add key="ClientValidationEnabled" value="true"/>
    <add key="UnobtrusiveJavaScriptEnabled" value="true"/>
    <add key="EmailSmtp" value="smtp.gmail.com"/>
    <add key="EmailSmtpPort" value="587"/>
    <add key="EmailUsername" value="taxdoctorsa@gmail.com"/>
    <add key="EmailPassword" value="x1Casper#73"/>
    <add key="EmailFrom" value="taxdoctorsa@gmail.com"/>
    <add key="EmailTo" value="jagberg@gmail.com"/>
    <add key="EmailSubject" value="New Tax Doctor Enquiry"/>
    <add key="log4net.Internal.Debug" value="true"/>
  </appSettings>

  <log4net>

    <root>
      <!--Change to DEBUG to ignore INFO messages-->
      <!--level value="DEBUG" /-->
      <level value="INFO"/>
      <appender-ref ref="RollingFileAppender"/>
    </root>

    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="taxdoctorlog.txt"/>
      <appendToFile value="true"/>
      <rollingStyle value="Size"/>
      <maxSizeRollBackups value="5"/>
      <maximumFileSize value="10MB"/>
      <staticLogFileName value="true"/>
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="%date %level - %message%newline"/>
      </layout>
    </appender>
  </log4net>

  <!--
    For a description of web.config changes for .NET 4.5 see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.5" />
      </system.Web>
  -->
  <system.web>
    <compilation debug="true" targetFramework="4.0"/>

    <!--If google blocks the use of smtp the following exception will occur: The SMTP server requires a secure connection or the client was not authenticated. The server response was: 5.5.1 Authentication Required
    You need to login to taxdoctorsa@gmail.com and allow access from that location.-->

    <!--Without full trust you get the following exception: System.Security.SecurityException: Request for the permission of type 'System.Net.Mail.SmtpPermission-->
    <trust level="Full" originUrl=""/>

  </system.web>
  
  <!--TaxDoctor: Required config entry for logging-->
  <system.diagnostics>
    <trace autoflush="true">
      <listeners>
        <add name="textWriterTraceListener" type="System.Diagnostics.TextWriterTraceListener" initializeData="log4net.txt"/>
      </listeners>
    </trace>
  </system.diagnostics>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Helpers" publicKeyToken="31bf3856ad364e35"/>
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.WebPages" publicKeyToken="31bf3856ad364e35"/>
        <bindingRedirect oldVersion="1.0.0.0-3.0.0.0" newVersion="3.0.0.0"/>
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Web.Mvc" publicKeyToken="31bf3856ad364e35"/>
        <bindingRedirect oldVersion="1.0.0.0-5.2.2.0" newVersion="5.2.2.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>