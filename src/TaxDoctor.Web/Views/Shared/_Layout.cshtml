<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8">
    @*<title>Tax Doctor - Affordable accounting, bookkeeping, payroll and tax returns</title>*@
    <title>Tax Doctor - @ViewBag.PageTitle</title>
    <link href="@Url.Content("~/Content/NewLook.css")" rel="stylesheet" type="text/css" />

    @* Favicons *@
    <link rel="apple-touch-icon" sizes="180x180" href="@Url.Content("~/Content/favicons/apple-touch-icon.png")">
    <link rel="icon" type="image/png" sizes="32x32" href="@Url.Content("~/Content/favicons/favicon-32x32.png")">
    <link rel="icon" type="image/png" sizes="16x16" href="@Url.Content("~/Content/favicons/favicon-16x16.png")">
    <link rel="manifest" href="@Url.Content("~/Content/favicons/site.webmanifest.json")">

    <meta name="description" content="@ViewBag.MetaDescription">
    <meta name="keywords" content="@ViewBag.MetaKeywords">
    <script src="@Url.Content("~/Scripts/GoogleAnalyticsTracking.js")" type="text/javascript"></script>
    <!-- Google Tag Manager -->
    <script>
    (function (w, d, s, l, i) {
        w[l] = w[l] || []; w[l].push({
            'gtm.start':
                new Date().getTime(), event: 'gtm.js'
        }); var f = d.getElementsByTagName(s)[0],
            j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', 'GTM-M682998');</script>
    <!-- End Google Tag Manager -->
</head>
<body>
    <!-- Google Tag Manager (noscript) -->
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M682998"
                height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div id="header">
        <img class="image-package" alt="Tax Doctor" src="@Url.Content("~/Content/images/taxdoctorlogo.png")">
        <h1>
            Tax Doctor
        </h1>
    </div>
    <ul id="nav">
        <li>
            @Html.ActionLink("Home", "Index", "Home")
        </li>
        <li>
            <strong>Our Services</strong>
            <ul>
                <li>@Html.ActionLink("Accounting", "Accounting", "Services", null, new { title = "Accounting Services"})</li>
                <li>@Html.ActionLink("Bank Loan Applications", "BankLoanApplications", null, new { title = "Bank Loan Applications" })</li>
                <li>@Html.ActionLink("Bookkeeping", "Bookkeeping", "Services", null, new { title = "Bookkeeping Services" })</li>
                <li>@Html.ActionLink("Company Formations", "CompanyFormations", "Services", null, new { title = "Company Formation Services" })</li>
                <li>@Html.ActionLink("Payroll", "Payroll", "Services", null, new { title = "Payroll Services" })</li>
                <li>@Html.ActionLink("Tax Services", "TaxServices", "Services", null, new { title = "Tax Services"})</li>
            </ul>
        </li>
        <li>
        <li>
            @Html.ActionLink("Training", "Training", "Training", null, new { title = "Training" })
        </li>
        <li>
            @Html.ActionLink("Prices", "Prices", "Services", null, new { title = "Prices" })
        </li>
        <li>
            @Html.ActionLink("About Us", "About", "Home", null, new { title = "About Us" })
        </li>
    </ul>
    <div id="stage">
        @*
            <h2>
                Tax Doc
            </h2>*@
    </div>
    <div id="article">
        <div class="contactus">
            <div id="ContactForm">
                @{ Html.RenderAction("ContactUs", "Contact"); }
            </div>
        </div>
        @RenderBody()
    </div>
    <div id="footer">
        <div>
            <dl>
                <dt>Our Services</dt>
                <dd>@Html.ActionLink("Accounting", "Accounting", "Services", null, new { title = "Accounting Services" })</dd>
                <dd>@Html.ActionLink("Bank Loan Applications", "BankLoanApplications", "Services", null, new { title = "Bank Loan Applications" })</dd>
                <dd>@Html.ActionLink("Bookkeeping", "Bookkeeping", "Services", null, new { title = "Bookkeeping Services" })</dd>
                <dd>@Html.ActionLink("Company Formations", "CompanyFormations", "Services", null, new { title = "Company Formations" })</dd>
                <dd>@Html.ActionLink("Payroll", "Payroll", "Services", null, new { title = "Payroll Services" })</dd>
                <dd>@Html.ActionLink("Tax Services", "TaxServices", "Services", null, new { title = "Tax Services" })</dd>
            </dl>
            <dl>
                <dt>Our Prices </dt>
                <dd>@Html.ActionLink("Prices", "Prices", "Services", null, new { title = "Prices" })</dd>
            </dl>
            <dl>
                <dt>Training</dt>
                <dd>
                    @Html.ActionLink("Training", "Training", "Training", null, new { title = "Training" })
                </dd>
            </dl>
            Address:
            <address>
                73 Mackay Avenue, Blairgowrie, Randburg, 2194
            </address>
        </div>
        <div id="meta">
            © @System.DateTime.Today.Year Tax Doctor
            <ul>
                <li>
                    <a class="social" href="http://facebook.com/taxdoctorsa">
                        <img alt="Facebook" src="@Url.Content("~/Content/images/f_logo_RGB-Blue_58.png")">
                    </a>
                    <a href="http://twitter.com/mytaxdoctor">
                        <img alt="Twitter" src="@Url.Content("~/Content/images/Twitter_Social_Icon_Circle_Color.svg")">
                    </a>
                </li>
            </ul>
        </div>
    </div>
</body>

<script src="@Url.Content("~/Scripts/jquery-1.5.1.min.js")" type="text/javascript"></script>
<script src="@Url.Content("~/Scripts/jquery.unobtrusive-ajax.min.js")" type="text/javascript"></script>
</html>
