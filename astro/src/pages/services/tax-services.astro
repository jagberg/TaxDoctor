import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Tax Services"
  description="Tax Doctor handles all personal and business tax submissions including IT12, IT14, VAT201, EMP201, EMP501, IRP5 and tax clearance certificates."
  keywords="tax services, it12, it14, vat201, emp201, emp501, irp5, irp6, tax clearance, sars efiling, johannesburg"
>
  <div class="section">
    <img class="image-section" alt="Tax Services" src="/images/Services/taxtax.jpg" />
    <h2>Tax Services</h2>

    <p>
      <b>Individuals</b> are required to submit annual and in some cases bi-annual tax returns,
      which can include:
    </p>
    <ul class="alt">
      <li>IT12 — Annual submission of income, expenses, assets and liabilities</li>
      <li>IRP5</li>
      <li>IRP6</li>
    </ul>

    <p>
      <b>Businesses</b> are required to submit bi-monthly to annual tax returns:
    </p>
    <li><b>SARS eFiling Services</b></li>
    <ul class="alt">
      <li>IT14 — Annual submission of company details to SARS (incl. CK, VAT, PAYE numbers, income, expenses, assets and liabilities)</li>
      <li>VAT201 — Monthly / bi-monthly returns</li>
      <li>VAT Audits</li>
      <li>EMP201 — Monthly PAYE, SDL, UIF returns and payments</li>
      <li>IRP6</li>
      <li>Tax Clearance Certificates</li>
    </ul>
    <li><b>SARS e@syFile Services</b></li>
    <ul class="alt">
      <li>IRP5</li>
      <li>EMP501 reconciliation</li>
    </ul>
  </div>
</Layout>
