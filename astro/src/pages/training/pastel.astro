---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Pastel Payroll Training"
  description="Pastel Payroll training in Johannesburg — setup, employees, payslips, IRP5, EMP501, EMP201 and year-end procedures."
  keywords="pastel payroll training, pastel payroll, irp5, emp501, emp201, year end, johannesburg"
>
  <div class="section">
    <h2>Pastel Payroll Training</h2>
    <img class="image-package" alt="Pastel Payroll" src="/images/Training/pastel.jpg" />
    <p>
      Pastel Payroll — SA's leading developer of Payroll solutions for all business sizes.
    </p>
    <p>
      We will teach you how to setup a company from scratch and enter new employees. We will
      also show you how to enter salary details and print payslips as well as generate reports
      for tax and management information. We will show you how to produce IRP5s and do EMP501,
      EMP201 as well as year-end procedures and reports.
    </p>
  </div>
</Layout>
