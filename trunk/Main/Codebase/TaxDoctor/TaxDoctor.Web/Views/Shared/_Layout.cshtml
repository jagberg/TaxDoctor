                <li>@Html.ActionLink("Excel", "Excel", "Training")</li>
            </ul>
        </li>
        <li>@Html.ActionLink("About Us", "About", "Home")
        </li>
    </ul>
    <div id="stage">@*
        <h2>
            Tax Doc
        </h2>*@
    </div>
