        .type-3 .g-button-basic {
            float: right;
            margin: 0 0 0 20px;
        }

        iframe {
            width: 723px;
            height: 330px;
        }

        .media {
            float: none;
            margin: 0px;
            width: auto;
        }

            .media div {
                margin: 0 0 5px;
            }

                .media div p {
                    font-size: 12px;
                    line-height: 20px;
                }

            .media a.more {
                font-weight: bold;
            }

        #webinars a {
            font-weight: normal;
        }
    </style>
    <style>
        a.c1 {
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div id="header">
